<?xml version="1.0"?>
<Container version="2">
  <Name>Beamlet</Name>
  <Repository>ghcr.io/mondominator/beamlet:latest</Repository>
  <Registry>ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/mondominator/beamlet</Project>
  <Overview>Beamlet is a self-hosted file sharing server. Share photos, videos, documents, and messages with push notifications. Personal AirDrop replacement that works anywhere.</Overview>
  <Category>Productivity: Cloud:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/mondominator/beamlet/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web Port" Target="8080" Default="8080" Mode="tcp" Description="Server port" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/beamlet" Mode="rw" Description="Database and file storage" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/beamlet</Config>
  <Config Name="APNs Key File" Target="/app/apns_key.p8" Default="/mnt/user/appdata/beamlet/apns_key.p8" Mode="ro" Description="Apple Push Notification key (.p8 file)" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/beamlet/apns_key.p8</Config>
  <Config Name="APNs Key ID" Target="BEAMLET_APNS_KEY_ID" Default="" Mode="" Description="APNs Key ID from Apple Developer" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="APNs Team ID" Target="BEAMLET_APNS_TEAM_ID" Default="" Mode="" Description="Apple Developer Team ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="APNs Bundle ID" Target="BEAMLET_APNS_BUNDLE_ID" Default="com.beamlet.app" Mode="" Description="iOS app bundle identifier" Type="Variable" Display="always" Required="false" Mask="false">com.beamlet.app</Config>
  <Config Name="APNs Key Path" Target="BEAMLET_APNS_KEY_PATH" Default="/app/apns_key.p8" Mode="" Description="Path to APNs key inside container" Type="Variable" Display="advanced" Required="false" Mask="false">/app/apns_key.p8</Config>
  <Config Name="Max File Size" Target="BEAMLET_MAX_FILE_SIZE" Default="524288000" Mode="" Description="Maximum upload size in bytes (default 500MB)" Type="Variable" Display="advanced" Required="false" Mask="false">524288000</Config>
  <Config Name="Expiry Days" Target="BEAMLET_EXPIRY_DAYS" Default="30" Mode="" Description="Days before files auto-expire (0 = never)" Type="Variable" Display="advanced" Required="false" Mask="false">30</Config>
  <Config Name="External URL" Target="BEAMLET_EXTERNAL_URL" Default="" Mode="" Description="Public URL for invite links (e.g. https://beamlet.example.com)" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
